generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slide {
  id        String   @id @default(uuid())
  title     String
  image     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeContent {
  id                    String   @id @default(uuid())
  heroTitle             String?
  heroTagline           String?
  storyTitle            String?
  storyDescription      String?  @db.Text
  visionTitle           String?
  visionDescription     String?  @db.Text
  founderTitle          String?
  founderDescription    String?  @db.Text
  experienceTitle       String?
  experienceDescription String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Navigation {
  id        String   @id @default(uuid())
  label     String
  path      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          String   @id @default(uuid())
  name        String?
  tagline     String?
  description String?  @db.Text
  founder     String?
  address     String?  @db.Text
  instagram   String?
  linkedin    String?
  youtube     String?
  pinterest   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscoverContent {
  id                    String   @id @default(uuid())
  heroTitle             String?
  heroSubtitle          String?
  heroDescription       String?  @db.Text
  heroImage             String?
  philosophyHeading     String?
  philosophyParagraphs  String?  @db.Text
  craftsmanshipTitle    String?
  craftsmanshipItems    String?  @db.Text
  craftsmanshipImage    String?
  valuesTitle           String?
  valuesCards           String?  @db.Text
  galleryTitle          String?
  galleryImages         String?  @db.Text
  ctaTitle              String?
  ctaButtonText         String?
  ctaLink               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ShopContent {
  id                  String   @id @default(uuid())
  heroTitle           String?
  heroSubtitle        String?
  heroDescription     String?  @db.Text
  heroImage           String?
  featuredTitle       String?
  featuredItems       String?  @db.Text
  products            String?  @db.Text
  storyTitle          String?
  storyParagraphs     String?  @db.Text
  ctaTitle            String?
  ctaDescription      String?  @db.Text
  ctaButtonText       String?
  ctaLink             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LatestContent {
  id                      String   @id @default(uuid())
  heroTitle               String?
  heroSubtitle            String?
  heroDescription         String?  @db.Text
  featuredArticle         String?  @db.Text
  articles                String?  @db.Text
  highlightsTitle         String?
  highlightsTopics        String?  @db.Text
  newsletterTitle         String?
  newsletterDescription   String?  @db.Text
  newsletterCta           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CommunityContent {
  id                    String   @id @default(uuid())
  heroTitle             String?
  heroSubtitle          String?
  heroDescription       String?  @db.Text
  heroImage             String?
  storiesTitle          String?
  stories               String?  @db.Text
  testimonialsTitle     String?
  testimonials          String?  @db.Text
  experiencesTitle      String?
  experiences           String?  @db.Text
  galleryTitle          String?
  galleryImages         String?  @db.Text
  ctaTitle              String?
  ctaDescription        String?  @db.Text
  ctaButtonText         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NoteContent {
  id                    String   @id @default(uuid())
  heroTitle             String?
  heroSubtitle          String?
  heroDescription       String?  @db.Text
  heroImage             String?
  letterTitle           String?
  letterSalutation      String?
  letterParagraphs      String?  @db.Text
  letterImage           String?
  editorialTitle        String?
  editorialContent      String?  @db.Text
  signatureName         String?
  signatureRole         String?
  signatureBio          String?  @db.Text
  signatureImage        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Media {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  size         Int
  mimeType     String
  url          String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String   @db.Text
  shortDesc         String?
  price             Decimal
  stock             Int      @default(0)
  sku               String?  @unique
  lowStockThreshold Int      @default(5)
  trackInventory    Boolean  @default(true)
  category          String?
  featured          Boolean  @default(false)
  active            Boolean  @default(true)
  image             String?
  gallery           Json?
  seoTitle          String?
  seoDescription    String?  @db.Text
  seoKeywords       String?  @db.Text
  reviews           Review[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
  @@index([category])
}

model SEO {
  id                 String   @id @default(uuid())
  pageKey            String   @unique
  title              String?
  description        String?  @db.Text
  keywords           String?  @db.Text
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?  @db.Text
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?  @db.Text
  twitterImage       String?
  schemaMarkup       String?  @db.Text
  updatedAt          DateTime @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  customerId String
  rating     Int
  title      String?
  comment    String?  @db.Text
  approved   Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Coupon {
  id                 String   @id @default(uuid())
  code               String   @unique
  description        String?
  discountType       String   // "PERCENTAGE" | "FIXED"
  discountValue      Decimal
  minimumOrderAmount Decimal  @default(0)
  maxDiscount        Decimal?
  usageLimit         Int?
  usedCount          Int      @default(0)
  active             Boolean  @default(true)
  expiresAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  addresses Address[]
  orders    Order[]
  reviews   Review[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Address {
  id           String   @id @default(uuid())
  customerId   String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id             String    @id @default(uuid())
  orderNumber    String    @unique
  customerId     String?
  customerName   String
  customerEmail  String?
  customerPhone  String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  pincode        String
  subtotal       Decimal
  discount       Decimal   @default(0)
  couponCode     String?
  shipping       Decimal
  total          Decimal
  paymentMethod  String    @default("COD")
  paymentStatus  String    @default("PENDING")
  orderStatus    String    @default("PENDING")
  trackingNumber String?
  estimatedDeliveryDate DateTime?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  items          OrderItem[]
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([orderNumber])
  @@index([orderStatus])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  productName String
  price       Decimal
  quantity    Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  image       String?
  articles    Article[]
  createdAt   DateTime  @default(now())
}

model Tag {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  articles  ArticleTag[]
}

model Author {
  id          String    @id @default(uuid())
  name        String
  designation String?
  bio         String?   @db.Text
  image       String?
  socials     Json?
  articles    Article[]
  createdAt   DateTime  @default(now())
}

model Article {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  excerpt          String?      @db.Text
  content          String       @db.LongText
  featuredImage    String?
  status           String       @default("DRAFT") // "DRAFT" | "PUBLISHED"
  categoryId       String?
  authorId         String?
  publishedAt      DateTime?
  readTime         Int?         @default(0)
  views            Int          @default(0)
  
  // SEO Fields
  metaTitle        String?
  metaDescription  String?      @db.Text
  keywords         String?      @db.Text
  ogTitle          String?
  ogDescription    String?      @db.Text
  ogImage          String?
  canonicalUrl     String?
  schemaMarkup     String?      @db.Text

  category         Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author           Author?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  tags             ArticleTag[]
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model WebsiteSettings {
  id                  String   @id @default(uuid())
  siteName            String   @default("shef&B")
  siteTagline         String?
  footerCopyrightText String?
  logoImage           String?
  faviconImage        String?

  contactEmail        String?
  contactPhone        String?
  contactWhatsapp     String?
  contactAddress      String?  @db.Text
  googleMapsUrl       String?  @db.Text

  socialInstagram     String?
  socialFacebook      String?
  socialLinkedin      String?
  socialYoutube       String?
  socialPinterest     String?
  socialTwitter       String?

  codEnabled          Boolean  @default(true)
  onlinePaymentEnabled Boolean @default(false)
  flatShippingCost    Decimal  @default(0)
  freeShippingThreshold Decimal @default(0)
  taxPercentage       Decimal  @default(0)

  announcementEnabled Boolean  @default(false)
  announcementText    String?
  announcementCtaText String?
  announcementCtaLink String?

  updatedAt           DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  status    String   @default("NEW") // "NEW", "IN_PROGRESS", "CLOSED"
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
